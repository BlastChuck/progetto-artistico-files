_ESTERNO {\n    partita_iva (id),\n    ragione_sociale,\n    tipologia,\n    referente,\n    contatti (multi),\n    affidabilita (optional)\n}\nentity CORRIERE {\n    codice_corriere (id),\n    azienda,\n    certificazione,\n    targa (multi)\n}\nentity MOSTRA_EVENTO {\n    codice_evento (id),\n    titolo,\n    tema,\n    data_inizio,\n    data_fine,\n    curatore,\n    budget\n}\nentity CONCORSO {\n    codice_concorso (id),\n    ente_organizzatore,\n    livello\n}\nentity PRESTITO {\n    codice_prestito (id),\n    data_inizio_prevista,\n    data_fine_prevista,\n    luogo_destinazione,\n    scopo,\n    stato,\n    data_inizio_effettiva (optional),\n    data_fine_effettiva (optional)\n}\nentity CRITICA_FORMATIVA {\n    codice_critica (id),\n    data,\n    testo\n}\nentity VALUTAZIONE_UFFICIALE {\n    codice_valutazione (id),\n    data,\n    voto_tecnica,\n    voto_originalita,\n    voto_messaggio,\n    voto_finale,\n    quadrimestre\n}\nentity OPERA {\n    codice_opera (id),\n    titolo,\n    anno_creazione,\n    stato_lavorazione,\n    descrizione (optional),\n    valore_stimato (optional)\n}\nentity OPERA_FISICA {\n    dimensioni,\n    peso,\n    fragilita,\n    requisiti_conservazione\n}\nentity OPERA_DIGITALE {\n    formato,\n    peso_file,\n    risoluzione,\n    url\n}\n\n/* Relationships */\nrelationship REALIZZA (\n    STUDENTE: one..many,\n    OPERA: one..many\n)\nrelationship UTILIZZA (\n    OPERA: one..many,\n    TECNICA_MATERIALE: one..many\n)\nrelationship COLLOCATA (\n    OPERA_FISICA: one..one,\n    SPAZIO_ESPOSITIVO: zero..many\n)\nrelationship ESPOSTA_IN (\n    OPERA: zero..many,\n    MOSTRA_EVENTO: zero..many\n)\nrelationship PARTECIPA_A (\n    OPERA: zero..many,\n    CONCORSO: zero..many\n)\nrelationship ESPRIME (\n    DOCENTE: one..one,\n    CRITICA_FORMATIVA: zero..many\n)\nrelationship A (\n    CRITICA_FORMATIVA: zero..many,\n    OPERA: one..one\n)\nrelationship ASSEGNA_VOTO (\n    DOCENTE: one..one,\n    VALUTAZIONE_UFFICIALE: zero..many\n)\nrelationship ALL (\n    VALUTAZIONE_UFFICIALE: zero..many,\n    OPERA: one..one\n)\nrelationship COINVOLGE (\n    OPERA: one..one,\n    PRESTITO: zero..many\n)\nrelationship RICHIEDE (\n    PRESTITO: zero..many,\n    ENTE_ESTERNO: one..one\n)\nrelationship TRASPORTA (\n    PRESTITO: zero..many,\n    CORRIERE: one..one\n)\n\n/* Generalizations */\nOPERA <= {\n    OPERA_DIGITALE,\n    OPERA_FISICA\n} (partial, exclusive)","sqlCode":"","itemsArray":[{"__type":"Entity","_id":1,"_name":"STUDENTE","_x":-2397,"_y":-975,"_mag":false},{"__type":"Entity","_id":2,"_name":"DOCENTE","_x":-683,"_y":-380,"_mag":false},{"__type":"Entity","_id":3,"_name":"TECNICA_MATERIALE","_x":-2371,"_y":-643,"_mag":false},{"__type":"Entity","_id":4,"_name":"SPAZIO_ESPOSITIVO","_x":-258,"_y":-1259,"_mag":false},{"__type":"Entity","_id":5,"_name":"ENTE_ESTERNO","_x":0,"_y":-1074,"_mag":false},{"__type":"Entity","_id":6,"_name":"CORRIERE","_x":1,"_y":-816,"_mag":false},{"__type":"Entity","_id":7,"_name":"MOSTRA_EVENTO","_x":-769,"_y":-764,"_mag":false},{"__type":"Entity","_id":8,"_name":"CONCORSO","_x":-1838,"_y":-428,"_mag":false},{"__type":"Entity","_id":9,"_name":"PRESTITO","_x":-695,"_y":-1068,"_mag":false},{"__type":"Entity","_id":10,"_name":"CRITICA_FORMATIVA","_x":-1067,"_y":-567,"_mag":false},{"__type":"Entity","_id":11,"_name":"VALUTAZIONE_UFFICIALE","_x":-1336,"_y":-213,"_mag":false},{"__type":"Entity","_id":12,"_name":"OPERA","_x":-1512,"_y":-970,"_mag":false},{"__type":"Relationship","_id":13,"_name":"REALIZZA","_x":-2000,"_y":-972},{"__type":"Participation","_id":15,"_entityId":1,"_tableId":null,"_relationshipId":13,"_cardinality":"1_N","_externalIdentifier":false,"_role":""},{"__type":"Participation","_id":16,"_entityId":12,"_tableId":null,"_relationshipId":13,"_cardinality":"1_N","_externalIdentifier":false,"_role":""},{"__type":"Relationship","_id":17,"_name":"UTILIZZA","_x":-1939,"_y":-656},{"__type":"Participation","_id":18,"_entityId":12,"_tableId":null,"_relationshipId":17,"_cardina