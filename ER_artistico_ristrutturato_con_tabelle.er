tity MOSTRA_EVENTO {\n    codice_evento (id),\n    titolo,\n    tema,\n    data_inizio,\n    data_fine,\n    curatore,\n    budget,\n    luogo\n}\nentity CONCORSO {\n    codice_concorso (id),\n    ente_organizzatore,\n    livello\n}\nentity PRESTITO {\n    codice_prestito (external),\n    data_inizio_prevista,\n    data_fine_prevista,\n    luogo_destinazione,\n    scopo,\n    stato,\n    data_inizio_effettiva (optional),\n    data_fine_effettiva (optional)\n}\nentity VALUTAZIONE_UFFICIALE {\n    codice_valutazione (external),\n    data,\n    voto_tecnica,\n    voto_originalita,\n    voto_messaggio,\n    voto_finale,\n    quadrimestre,\n    descrizione\n}\nentity OPERA {\n    codice_opera (id),\n    titolo,\n    anno_creazione,\n    stato_lavorazione,\n    descrizione (optional),\n    valore_stimato (optional)\n}\nentity OPERA_FISICA {\n    dimensioni,\n    peso,\n    fragilita,\n    requisiti_conservazione\n}\nentity OPERA_DIGITALE {\n    formato,\n    peso_file,\n    risoluzione,\n    url\n}\n\n/* Relationships */\nrelationship REALIZZA (\n    STUDENTE: one..many,\n    OPERA: one..many\n)\nrelationship UTILIZZA (\n    OPERA: one..many,\n    TECNICA_MATERIALE: one..many\n)\nrelationship ESPOSTA_IN (\n    OPERA: zero..many,\n    MOSTRA_EVENTO: zero..many\n)\nrelationship PARTECIPA_A (\n    OPERA: zero..many,\n    CONCORSO: zero..many\n)\nrelationship ASSEGNA_VOTO (\n    DOCENTE: zero..many,\n    VALUTAZIONE_UFFICIALE: one..one\n)\nrelationship ALL (\n    VALUTAZIONE_UFFICIALE: one..one external,\n    OPERA: one..many\n)\nrelationship COINVOLGE (\n    OPERA: zero..many,\n    PRESTITO: one..one external\n)\nrelationship RICHIEDE (\n    PRESTITO: zero..many,\n    ENTE_ESTERNO: one..one\n)\n\n/* Generalizations */\nOPERA <= {\n    OPERA_DIGITALE,\n    OPERA_FISICA\n} (total, exclusive)","sqlCode":"","itemsArray":[{"__type":"Entity","_id":1,"_name":"STUDENTE","_x":-2397,"_y":-975,"_mag":false},{"__type":"Entity","_id":2,"_name":"DOCENTE","_x":-683,"_y":-380,"_mag":false},