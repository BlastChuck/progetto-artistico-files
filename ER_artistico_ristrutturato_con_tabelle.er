{"_main":{"step":"schemaDesign","restructuringHappened":true,"draftSaved":true,"showMenu":false,"showModal":false,"containerWidth":500,"containerHeight":580,"uid":1},"erDesign":{"model":{"uid":138,"erCode":"/* Entities */\nentity STUDENTE {\n    c_f (id),\n    maticola,\n    nome,\n    cognome,\n    data_nascita,\n    classe_attuale,\n    sezione,\n    indirizzo_studi,\n    anno_immatricolazione,\n    media_voti (optional)\n}\nentity DOCENTE {\n    codice_docente (id),\n    c_f (id),\n    nome,\n    cognome,\n    materia_insegnata,\n    qualifica,\n    dipartimento,\n    anno_assunzione\n}\nentity TECNICA_MATERIALE {\n    codice_tecnica (id),\n    nome,\n    categoria,\n    tossicita (optional)\n}\nentity ENTE_ESTERNO {\n    partita_iva (id),\n    ragione_sociale,\n    tipologia,\n    referente,\n    contatti (multi),\n    affidabilita (optional)\n}\nentity MOSTRA_EVENTO {\n    codice_evento (id),\n    titolo,\n    tema,\n    data_inizio,\n    data_fine,\n    curatore,\n    budget,\n    luogo\n}\nentity CONCORSO {\n    codice_concorso (id),\n    ente_organizzatore,\n    livello\n}\nentity PRESTITO {\n    codice_prestito (external),\n    data_inizio_prevista,\n    data_fine_prevista,\n    luogo_destinazione,\n    scopo,\n    stato,\n    data_inizio_effettiva (optional),\n    data_fine_effettiva (optional)\n}\nentity VALUTAZIONE_UFFICIALE {\n    codice_valutazione (external),\n    data,\n    voto_tecnica,\n    voto_originalita,\n    voto_messaggio,\n    voto_finale,\n    quadrimestre,\n    descrizione\n}\nentity OPERA {\n    codice_opera (id),\n    titolo,\n    anno_creazione,\n    stato_lavorazione,\n    descrizione (optional),\n    valore_stimato (optional)\n}\nentity OPERA_FISICA {\n    dimensioni,\n    peso,\n    fragilita,\n    requisiti_conservazione\n}\nentity OPERA_DIGITALE {\n    formato,\n    peso_file,\n    risoluzione,\n    url\n}\n\n/* Relationships */\nrelationship REALIZZA (\n    STUDENTE: one..many,\n    OPERA: one..many\n)\nrelationship UTILIZZA (\n    OPERA: one..many,\n    TECNICA_MATERIALE: one..many\n)\nrelationship ESPOSTA_IN (\n    OPERA: zero..many,\n    MOSTRA_EVENTO: zero..many\n)\nrelationship PARTECIPA_A (\n    OPERA: zero..many,\n    CONCORSO: zero..many\n)\nrelationship ASSEGNA_VOTO (\n    DOCENTE: zero..many,\n    VALUTAZIONE_UFFICIALE: one..one\n)\nrelationship ALL (\n    VALUTAZIONE_UFFICIALE: one..one external,\n    OPERA: one..many\n)\nrelationship COINVOLGE (\n    OPERA: zero..many,\n    PRESTITO: one..one external\n)\nrelationship RICHIEDE (\n    PRESTITO: zero..many,\n    ENTE_ESTERNO: one..one\n)\n\n/* Generalizations */\nOPERA <= {\n    OPERA_DIGITALE,\n    OPERA_FISICA\n} (total, exclusive)","sqlCode":"","itemsArray":[{"__type":"Entity","_id":1,"_name":"STUDENTE","_x":-2397,"_y":-975,"_mag":false},{"__type":"Entity","_id":2,"_name":"DOCENTE","_x":-683,"_y":-380,"_mag":false},{"__type":"Entity","_id":3,"_name":"TECNICA_MATERIALE","_x":-2371,"_y":-643,"_mag":false},{"__type":"Entity","_id":5,"_name":"ENTE_ESTERNO","_x":0,"_y":-1074,"_mag":false},{"__type":"Entity","_id":7,"_name":"MOSTRA_EVENTO","_x":-785,"_y":-748,"_mag":false},{"__type":"Entity","_id":8,"_name":"CONCORSO","_x":-1838,"_y":-428,"_mag":false},{"__type":"Entity","_id":9,"_name":"PRESTITO","_x":-695,"_y":-1068,"_mag":false},{"__type":"Entity","_id":11,"_name":"VALUTAZIONE_UFFICIALE","_x":-1350,"_y":-199,"_mag":false},{"__type":"Entity","_id":12,"_name":"OPERA","_x":-1512,"_y":-970,"_mag":false},{"__type":"Relationship","_id":13,"_name":"REALIZZA","_x":-2000,"_y":-972},{"__type":"Participation","_id":15,"_entityId":1,"_tableId":null,"_relationshipId":13,"_cardinality":"1_N","_externalIdentifier":false,"_role":""},{"__type":"Participation","_id":16,"_entityId":12,"_tableId":null,"_relationshipId":13,"_cardinality":"1_N","_externalIdentifier":false,"_role":""},{"__type":"Relationship","_id":17,"_name":"UTILIZZA","_x":-1939,"_y":-656},{"__type":"Participation","_id":18,"_entityId":12,"_tableId":null,"_relationshipId":17,"_cardinal