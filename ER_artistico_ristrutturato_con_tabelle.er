/\nentity STUDENTE {\n    c_f (id),\n    maticola,\n    nome,\n    cognome,\n    data_nascita,\n    classe_attuale,\n    sezione,\n    indirizzo_studi,\n    anno_immatricolazione,\n    media_voti (optional)\n}\nentity DOCENTE {\n    codice_docente (id),\n    c_f (id),\n    nome,\n    cognome,\n    materia_insegnata,\n    qualifica,\n    dipartimento,\n    anno_assunzione\n}\nentity TECNICA_MATERIALE {\n    codice_tecnica (id),\n    nome,\n    categoria,\n    tossicita (optional)\n}\nentity ENTE_ESTERNO {\n    partita_iva (id),\n    ragione_sociale,\n    tipologia,\n    referente,\n    contatti (multi),\n    affidabilita (optional)\n}\nentity MOSTRA_EVENTO {\n    codice_evento (id),\n    titolo,\n    tema,\n    data_inizio,\n    data_fine,\n    curatore,\n    budget,\n    luogo\n}\nentity CONCORSO {\n    codice_concorso (id),\n    ente_organizzatore,\n    livello\n}\nentity PRESTITO {\n    codice_prestito (external),\n    data_inizio_prevista,\n    data_fine_prevista,\n    luogo_destinazione,\n    scopo,\n    stato,\n    data_inizio_effettiva (optional),\n    data_fine_effettiva (optional)\n}\nentity VALUTAZIONE_UFFICIALE {\n    codice_valutazione (external),\n    data,\n    voto_tecnica,\n    voto_originalita,\n    voto_messaggio,\n    voto_finale,\n    quadrimestre,\n    descrizione\n}\nentity OPERA {\n    codice_opera (id),\n    titolo,\n    anno_creazione,\n    stato_lavorazione,\n    descrizione (optional),\n    valore_stimato (optional)\n}\nentity OPERA_FISICA {\n    dimensioni,\n    peso,\n    fragilita,\n    requisiti_conservazione\n}\nentity OPERA_DIGITALE {\n    formato,\n    peso_file,\n    risoluzione,\n    url\n}\n\n/* Relationships */\nrelationship REALIZZA (\n    STUDENTE: one..many,\n    OPERA: one..many\n)\nrelationship UTILIZZA (\n    OPERA: one..many,\n    TECNICA_MATERIALE: one..many\n)\nrelationship ESPOSTA_IN (\n    OPERA: zero..many,\n    MOSTRA_EVENTO: zero..many\n)\nrelationship PARTECIPA_A (\n    OPERA: zero..many,\n    CONCORSO: zero..many\n)\nrelationship ASSEGNA_VOTO (\n    DOCENTE: zero..many,\n    VALUTAZIONE_UFFICIALE: one..one\n)\nrelationship ALL (\n    VALUTAZIONE_UFFICIALE: one..one external,\n    OPERA: one..many\n)\nrelationship COINVOLGE (\n    OPERA: zero..many,\n    PRESTITO: one..one external\n)\nrelationship RICHIEDE (\n    PRESTITO: zero..many,\n    ENTE_ESTERNO: one..one\n)\n\n/* Generalizations */\nOPERA <= {\n    OPERA_DIGITALE,\n    OPERA_FISICA\n} (total, exclusive)","sqlCode":"/* Tables */\nCREATE TABLE STUDENTE (\n    c_f TEXT NOT NULL,\n    maticola TEXT NOT NULL,\n    nome TEXT NOT NULL,\n    cognome TEXT NOT NULL,\n    data_nascita TEXT NOT NULL,\n    classe_attuale TEXT NOT NULL,\n    sezione TEXT NOT NULL,\n    indirizzo_studi TEXT NOT NULL,\n    anno_immatricolazione TEXT NOT NULL,\n    media_voti TEXT,\n    PRIMARY KEY (c_f)\n);\nCREATE TABLE DOCENTE (\n    codice_docente TEXT NOT NULL,\n    c_f TEXT NOT NULL,\n    nome TEXT NOT NULL,\n    cognome TEXT NOT NULL,\n    materia_insegnata TEXT NOT NULL,\n    qualifica TEXT NOT NULL,\n    dipartimento TEXT NOT NULL,\n    anno_assunzione TEXT NOT NULL,\n    PRIMARY KEY (codice_docente, c_f)\n);\nCREATE TABLE TECNICA_MATERIALE (\n    codice_tecnica TEXT NOT NULL,\n    nome TEXT NOT NULL,\n    categoria TEXT NOT NULL,\n    tossicita TEXT,\n    PRIMARY KEY (codice_tecnica)\n);\nCREATE TABLE MOSTRA_EVENTO (\n    codice_evento TEXT NOT NULL,\n    titolo TEXT NOT NULL,\n    tema TEXT NOT NULL,\n    data_inizio TEXT NOT NULL,\n    data_fine TEXT NOT NULL,\n    curatore TEXT NOT NULL,\n    budget TEXT NOT NULL,\n    luogo TEXT NOT NULL,\n    PRIMARY KEY (codice_evento)\n);\nCREATE TABLE CONCORSO (\n    codice_concorso TEXT NOT NULL,\n    ente_organizzatore TEXT NOT NULL,\n    livello TEXT NOT NULL,\n    PRIMARY KEY (codice_concorso)\n);\nCREATE TABLE OPERA (\n    codice_opera TEXT NOT NULL,\n    titolo TEXT NOT NULL,\n    anno_creazione TEXT NOT NULL,\n    stato_lavorazione TEXT NOT NULL,\n    descrizione TEXT,\n    valore_stimato TEXT,\n    formato TEXT,\n    peso_file TEXT,\n    risoluzione TEXT,\n    url TEXT,\n    dimensioni TEXT,\n    peso TEXT,\n    fragilita TEXT,\n    requisiti_conservazione TEXT,\n    Type TEXT NOT NULL,\n    PRIMARY KEY (codice_opera)\n);\nCREATE TABLE ENTE_ESTERNO (\n    partita_iva TEXT NOT NULL,\n    ragione_sociale TEXT NOT NULL,\n    tipologia TEXT NOT NULL,\n    referente TEXT NOT NULL,\n    affidabilita TEXT,\n    PRESTITO_OPERA_codice_opera TEXT NOT NULL,\n    PRESTITO_codice_prestito TEXT NOT NULL,\n    PRIMARY KEY (partita_iva),\n    FOREIGN KEY (PRESTITO_OPERA_codice_opera, PRESTITO_codice_prestito) REFERENCES PRESTITO (OPERA_codice_opera, codice_prestito)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE CONTATTI (\n    contatti TEXT NOT NULL,\n    ENTE_ESTERNO_partita_iva TEXT NOT NULL,\n    PRIMARY KEY (contatti),\n    FOREIGN KEY (ENTE_ESTERNO_partita_iva) REFERENCES ENTE_ESTERNO (partita_iva)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE PRESTITO (\n    OPERA_codice_opera TEXT NOT NULL,\n    codice_prestito TEXT NOT NULL,\n    data_inizio_prevista TEXT NOT NULL,\n    data_fine_prevista TEXT NOT NULL,\n    luogo_destinazione TEXT NOT NULL,\n    scopo TEXT NOT NULL,\n    stato TEXT NOT NULL,\n    data_inizio_effettiva TEXT,\n    data_fine_effettiva TEXT,\n    PRIMARY KEY (OPERA_codice_opera, codice_prestito),\n    FOREIGN KEY (OPERA_codice_opera) REFERENCES OPERA (codice_opera)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE VALUTAZIONE_UFFICIALE (\n    OPERA_codice_opera TEXT NOT NULL,\n    codice_valutazione TEXT NOT NULL,\n    data TEXT NOT NULL,\n    voto_tecnica TEXT NOT NULL,\n    voto_originalita TEXT NOT NULL,\n    voto_messaggio TEXT NOT NULL,\n    voto_finale TEXT NOT NULL,\n    quadrimestre TEXT NOT NULL,\n    descrizione TEXT NOT NULL,\n    DOCENTE_codice_docente TEXT NOT NULL,\n    DOCENTE_c_f TEXT NOT NULL,\n    PRIMARY KEY (OPERA_codice_opera, codice_valutazione),\n    FOREIGN KEY (OPERA_codice_opera) REFERENCES OPERA (codice_opera)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (DOCENTE_codice_docente, DOCENTE_c_f) REFERENCES DOCENTE (codice_docente, c_f)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE REALIZZA (\n    STUDENTE_c_f TEXT NOT NULL,\n    OPERA_codice_opera TEXT NOT NULL,\n    PRIMARY KEY (STUDENTE_c_f, OPERA_codice_opera),\n    FOREIGN KEY (STUDENTE_c_f) REFERENCES STUDENTE (c_f)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (OPERA_codice_opera) REFERENCES OPERA (codice_opera)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE UTILIZZA (\n    TECNICA_MATERIALE_codice_tecnica TEXT NOT NULL,\n    OPERA_codice_opera TEXT NOT NULL,\n    PRIMARY KEY (TECNICA_MATERIALE_codice_tecnica, OPERA_codice_opera),\n    FOREIGN KEY (TECNICA_MATERIALE_codice_tecnica) REFERENCES TECNICA_MATERIALE (codice_tecnica)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (OPERA_codice_opera) REFERENCES OPERA (codice_opera)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE ESPOSTA_IN (\n    MOSTRA_EVENTO_codice_evento TEXT NOT NULL,\n    OPERA_codice_opera TEXT NOT NULL,\n    PRIMARY KEY (MOSTRA_EVENTO_codice_evento, OPERA_codice_opera),\n    FOREIGN KEY (MOSTRA_EVENTO_codice_evento) REFERENCES MOSTRA_EVENTO (codice_evento)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (OPERA_codice_opera) REFERENCES OPERA (codice_opera)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE PARTECIPA_A (\n    CONCORSO_codice_concorso TEXT NOT NULL,\n    OPERA_codice_opera TEXT NOT NULL,\n    PRIMARY KEY (CONCORSO_codice_concorso, OPERA_codice_opera),\n    FOREIGN KEY (CONCORSO_codice_concorso) REFERENCES CONCORSO (codice_concorso)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (OPERA_codice_opera) REFERENCES OPERA (codice_opera)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);","itemsArray":[{"__ty