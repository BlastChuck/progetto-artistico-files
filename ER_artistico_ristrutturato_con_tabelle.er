p","_id":148,"_name":"HAS_CONTATTI","_x":-129,"_y":-1453},"149":{"__type":"Attribute","_id":149,"_name":"contatti","_identifier":true,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":147,"_x":-150,"_y":0},"150":{"__type":"Participation","_id":150,"_entityId":5,"_tableId":null,"_relationshipId":148,"_cardinality":"1_N","_externalIdentifier":false,"_role":""},"151":{"__type":"Participation","_id":151,"_entityId":147,"_tableId":null,"_relationshipId":148,"_cardinality":"1_1","_externalIdentifier":false,"_role":""}},"sqlLinearCode":""},"edited":false,"sceneResetToken":1776235324412,"selectedItemId":null,"oldRenamingValue":"","renamingValue":"","showRenamingInput":false,"showRenamingRoleInput":false,"showMultivalueAttributeMenu":false,"showCompositeAttributeMenu":false,"showGeneralizationMenu":false,"showExportMenu":false,"showNotes":false},"erTranslation":{"model":{"uid":282,"erCode":"/* Entities */\nentity STUDENTE {\n    c_f (id),\n    maticola,\n    nome,\n    cognome,\n    data_nascita,\n    classe_attuale,\n    sezione,\n    indirizzo_studi,\n    anno_immatricolazione,\n    media_voti (optional)\n}\nentity DOCENTE {\n    codice_docente (id),\n    c_f (id),\n    nome,\n    cognome,\n    materia_insegnata,\n    qualifica,\n    dipartimento,\n    anno_assunzione\n}\nentity TECNICA_MATERIALE {\n    codice_tecnica (id),\n    nome,\n    categoria,\n    tossicita (optional)\n}\nentity ENTE_ESTERNO {\n    partita_iva (id),\n    ragione_sociale,\n    tipologia,\n    referente,\n    contatti (multi),\n    affidabilita (optional)\n}\nentity MOSTRA_EVENTO {\n    codice_evento (id),\n    titolo,\n    tema,\n    data_inizio,\n    data_fine,\n    curatore,\n    budget,\n    luogo\n}\nentity CONCORSO {\n    codice_concorso (id),\n    ente_organizzatore,\n    livello\n}\nentity PRESTITO {\n    codice_prestito (external),\n    data_inizio_prevista,\n    data_fine_prevista,\n    luogo_destinazione,\n    scopo,\n    stato,\n    data_inizio_effettiva (optional),\n    data_fine_effettiva (optional)\n}\nentity VALUTAZIONE_UFFICIALE {\n    codice_valutazione (external),\n    data,\n    voto_tecnica,\n    voto_originalita,\n    voto_messaggio,\n    voto_finale,\n    quadrimestre,\n    descrizione\n}\nentity OPERA {\n    codice_opera (id),\n    titolo,\n    anno_creazione,\n    stato_lavorazione,\n    descrizione (optional),\n    valore_stimato (optional)\n}\nentity OPERA_FISICA {\n    dimensioni,\n    peso,\n    fragilita,\n    requisiti_conservazione\n}\nentity OPERA_DIGITALE {\n    formato,\n    peso_file,\n    risoluzione,\n    url\n}\n\n/* Relationships */\nrelationship REALIZZA (\n    STUDENTE: one..many,\n    OPERA: one..many\n)\nrelationship UTILIZZA (\n    OPERA: one..many,\n    TECNICA_MATERIALE: one..many\n)\nrelationship ESPOSTA_IN (\n    OPERA: zero..many,\n    MOSTRA_EVENTO: zero..many\n)\nrelationship PARTECIPA_A (\n    OPERA: zero..many,\n    CONCORSO: zero..many\n)\nrelationship ASSEGNA_VOTO (\n    DOCENTE: zero..many,\n    VALUTAZIONE_UFFICIALE: one..one\n)\nrelationship ALL (\n    VALUTAZIONE_UFFICIALE: one..one external,\n    OPERA: one..many\n)\nrelationship COINVOLGE (\n    OPERA: zero..many,\n    PRESTITO: one..one external\n)\nrelationship RICHIEDE (\n    PRESTITO: zero..many,\n    ENTE_ESTERNO: one..one\n)\n\n/* Generalizations */\nOPERA <= {\n    OPERA_DIGITALE,\n    OPERA_FISICA\n} (total, exclusive)","sqlCode":"","itemsArray":[{"__type":"Table","_id":152,"_name":"STUDENTE","_x":-2582,"_y":-1063,"_mag":false},{"__type":"Column","_id":154,"_name":"c_f","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":152,"_tableIndex":0},{"__type":"Column","_id":155,"_name":"maticola","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":152,"_tableIndex":1},{"__type":"Column","_id":156,"_name":"nome","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":152,"_tableIndex":2},{"__type":"Column","_id":157,"_name":"cognome","_type":"integer","_