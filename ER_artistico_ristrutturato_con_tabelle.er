e</u>, <u  style=\"text-decoration: underline;\">c_f</u>, nome, cognome, materia_insegnata, qualifica, dipartimento, anno_assunzione)<br><br>\nTECNICA_MATERIALE (<u  style=\"text-decoration: underline;\">codice_tecnica</u>, nome, categoria, tossicita*)<br><br>\nMOSTRA_EVENTO (<u  style=\"text-decoration: underline;\">codice_evento</u>, titolo, tema, data_inizio, data_fine, curatore, budget, luogo)<br><br>\nCONCORSO (<u  style=\"text-decoration: underline;\">codice_concorso</u>, ente_organizzatore, livello)<br><br>\nOPERA (<u  style=\"text-decoration: underline;\">codice_opera</u>, titolo, anno_creazione, stato_lavorazione, descrizione*, valore_stimato*, formato*, peso_file*, risoluzione*, url*, dimensioni*, peso*, fragilita*, requisiti_conservazione*, Type)<br><br>\nENTE_ESTERNO (<u  style=\"text-decoration: underline;\">partita_iva</u>, ragione_sociale, tipologia, referente, affidabilita*, PRESTITO_OPERA_codice_opera, PRESTITO_codice_prestito)<br><br>\nCONTATTI (<u  style=\"text-decoration: underline;\">contatti</u>, ENTE_ESTERNO_partita_iva)<br><br>\nPRESTITO (<u  style=\"text-decoration: underline;\">OPERA_codice_opera</u>, <u  style=\"text-decoration: underline;\">codice_prestito</u>, data_inizio_prevista, data_fine_prevista, luogo_destinazione, scopo, stato, data_inizio_effettiva*, data_fine_effettiva*)<br><br>\nVALUTAZIONE_UFFICIALE (<u  style=\"text-decoration: underline;\">OPERA_codice_opera</u>, <u  style=\"text-decoration: underline;\">codice_valutazione</u>, data, voto_tecnica, voto_originalita, voto_messaggio, voto_finale, quadrimestre, descrizione, DOCENTE_codice_docente, DOCENTE_c_f)<br><br>\nREALIZZA (<u  style=\"text-decoration: underline;\">STUDENTE_c_f</u>, <u  style=\"text-decoration: underline;\">OPERA_codice_opera</u>)<br><br>\nUTILIZZA (<u  style=\"text-decoration: underline;\">TECNICA_MATERIALE_codice_tecnica</u>, <u  style=\"text-decoration: underline;\">OPERA_codice_opera</u>)<br><br>\nESPOSTA_IN (<u  style=\"text-decoration: underline;\">MOSTRA_EVENTO_codice_evento</u>, <u  style=\"text-decoration: underline;\">OPERA_codice_opera</u>)<br><br>\nPARTECIPA_A (<u  style=\"text-decoration: underline;\">CONCORSO_codice_concorso</u>, <u  style=\"text-decoration: underline;\">OPERA_codice_opera</u>)<br><br>\n\n<br><h3>Referential integrity constraints</h3>\n\n\n\n\n\nENTE_ESTERNO (PRESTITO_OPERA_codice_opera, PRESTITO_codice_prestito)  REFERENCES PRESTITO  (OPERA_codice_opera, codice_prestito)<br><br>\nCONTATTI (ENTE_ESTERNO_partita_iva)  REFERENCES ENTE_ESTERNO  (partita_iva)<br><br>\nPRESTITO (OPERA_codice_opera)  REFERENCES OPERA  (codice_opera)<br><br>\nVALUTAZIONE_UFFICIALE (OPERA_codice_opera)  REFERENCES OPERA  (codice_opera)<br><br>VALUTAZIONE_UFFICIALE (DOCENTE_codice_docente, DOCENTE_c_f)  REFERENCES DOCENTE  (codice_docente, c_f)<br><br>\nREALIZZA (STUDENTE_c_f)  REFERENCES STUDENTE  (c_f)<br><br>REALIZZA (OPERA_codice_opera)  REFERENCES OPERA  (codice_opera)<br><br>\nUTILIZZA (TECNICA_MATERIALE_codice_tecnica)  REFERENCES TECNICA_MATERIALE  (codice_tecnica)<br><br>UTILIZZA (OPERA_codice_opera)  REFERENCES OPERA  (codice_opera)<br><br>\nESPOSTA_IN (MOSTRA_EVENTO_codice_evento)  REFERENCES MOSTRA_EVENTO  (codice_evento)<br><br>ESPOSTA_IN (OPERA_codice_opera)  REFERENCES OPERA  (codice_opera)<br><br>\nPARTECIPA_A (CONCORSO_codice_concorso)  REFERENCES CONCORSO  (codice_concorso)<br><br>PARTECIPA_A (OPERA_codice_opera)  REFERENCES OPERA  (codice_opera)<br><br>"},"edited":true,"sceneResetToken":1776235437308,"selectedItemId":null,"oldRenamingValue":"","renamingValue":"","showRenamingInput":false,"showDataTypeOptions":false,"showReorderingMenu":false,"showExportMenu":false},"editorData":null,"showNotesDataMenu":false}